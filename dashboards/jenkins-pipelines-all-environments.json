            "showValues": false,
            "spanNulls": 3600000,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": 0 }]
          },
          "unit": "ms"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "delivery - SUCCESS" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "delivery - FAILURE" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#E02F44", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "deploy - SUCCESS" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "deploy - FAILURE" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "hideZeros": false, "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.3.0-pre",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "bfh788kcgnpc0a" },
          "query": "from(bucket: \"jenkinsci\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"jenkins_data\")\n  |> filter(fn: (r) => r._field == \"build_time\")\n  |> filter(fn: (r) => r.project_name =~ /production/)\n  |> filter(fn: (r) => r.project_name =~ /^(delivery-|deploy-)/)\n  |> filter(fn: (r) => r.build_result == \"SUCCESS\" or r.build_result == \"FAILURE\")\n  |> map(fn: (r) => ({\n      _time: r._time,\n      _value: float(v: r._value),\n      category: (if r.project_name =~ /^delivery-/ then \"delivery\" else \"deploy\") + \" - \" + r.build_result\n  }))\n  |> group(columns: [\"category\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: true)",
          "refId": "A"
        }
      ],
      "title": "Production - Mean Time to Delivery & Deploy",
      "type": "timeseries"
    },
