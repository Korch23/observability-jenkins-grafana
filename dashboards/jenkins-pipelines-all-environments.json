      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "bfh788kcgnpc0a" },
          "query": "import \"strings\"\n\nfrom(bucket: \"jenkinsci\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"jenkins_data\")\n  |> filter(fn: (r) => r._field == \"build_number\")\n  |> filter(fn: (r) => r.project_name =~ /^delivery-/)\n  |> filter(fn: (r) => r.project_name =~ /production/)\n  |> filter(fn: (r) => r.build_result == \"FAILURE\")\n  |> map(fn: (r) => ({ r with service: strings.split(v: r.project_path, t: \"/\")[1] }))\n  |> keep(columns: [\"_time\", \"service\"])\n  |> map(fn: (r) => ({ _time: r._time, service: r.service, _value: 1.0 }))\n  |> group(columns: [\"service\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)",
          "refId": "A"
        }
      ],
      "title": "Production - Delivery Errors",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "influxdb", "uid": "bfh788kcgnpc0a" },
      "description": "Duracao media dos jobs delivery-*-production e deploy-*-production em todos os namespaces.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
